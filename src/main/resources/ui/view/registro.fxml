<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:id="contentPane"
           fx:controller="org.example.academia.ui.controller.RegistroController"
           stylesheets="@../styles/dashboard.css"
           styleClass="login-pane"
           alignment="CENTER"
           prefWidth="1040" prefHeight="862"
           minWidth="900" minHeight="746"
           maxWidth="Infinity" maxHeight="Infinity">
    <VBox alignment="CENTER" spacing="14.0" styleClass="login-card"
          prefWidth="400" maxWidth="440" prefHeight="420" maxHeight="460"
          translateY="-30">
        <Label text="Registro de usuario" styleClass="content-title"/>

        <TextField fx:id="nombreCompletoField" promptText="Nombre completo" maxWidth="250"/>
        <TextField fx:id="emailField" promptText="Correo electrónico" maxWidth="250"/>
        <TextField fx:id="usernameField" promptText="Usuario" maxWidth="250"/>
        <PasswordField fx:id="passwordField" promptText="Contraseña" maxWidth="250"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirmar contraseña" maxWidth="250"/>

        <Button text="Registrar" onAction="#onRegister" maxWidth="250" styleClass="login-button"/>
        <Hyperlink text="Volver al login" onAction="#onBackToLogin" styleClass="login-link"/>

        <Label fx:id="messageLabel" textFill="red"/>
    </VBox>
</StackPane>
