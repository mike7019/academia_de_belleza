<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.academia.ui.controller.EstudianteController">
    <top>
        <VBox spacing="10.0">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="Gestión de Estudiantes" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <HBox spacing="10.0">
                <Button text="Nuevo Estudiante" onAction="#onNuevoEstudiante"/>
                <Button text="Editar" onAction="#onEditarEstudiante"/>
                <Button text="Inactivar" onAction="#onInactivarEstudiante"/>
                <Button text="Ver Matrículas"/>
            </HBox>
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label text="Nombre:"/>
                <TextField fx:id="filtroNombreField" promptText="Buscar por nombre" prefWidth="180"/>
                <Label text="Documento:"/>
                <TextField fx:id="filtroDocumentoField" promptText="Buscar por documento" prefWidth="160"/>
                <Label text="Estado:"/>
                <ComboBox fx:id="filtroEstadoCombo" prefWidth="140"/>
                <Button text="Buscar" onAction="#onFiltrarEstudiantes"/>
                <Button text="Limpiar" onAction="#onLimpiarFiltros"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="estudiantesTable">
            <columns>
                <TableColumn fx:id="nombreColumn" text="Nombre" prefWidth="150"/>
                <TableColumn fx:id="apellidoColumn" text="Apellido" prefWidth="150"/>
                <TableColumn fx:id="documentoColumn" text="Documento" prefWidth="120"/>
                <TableColumn fx:id="telefonoColumn" text="Teléfono" prefWidth="120"/>
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="200"/>
                <TableColumn fx:id="activoColumn" text="Activo" prefWidth="80"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <HBox spacing="10.0" alignment="CENTER_RIGHT" style="-fx-padding: 8 10 8 10;">
            <Label fx:id="resumenPaginaLabel" text="Mostrando 0 de 0"/>
            <Pagination fx:id="paginacionEstudiantes" maxPageIndicatorCount="7"/>
        </HBox>
    </bottom>
</BorderPane>

