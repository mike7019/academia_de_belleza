<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.academia.ui.controller.LoginController">
    <center>
        <VBox alignment="CENTER" spacing="10.0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label text="Academia de Belleza" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <TextField fx:id="usernameField" promptText="Usuario" maxWidth="200"/>
            <PasswordField fx:id="passwordField" promptText="Contraseña" maxWidth="200"/>
            <Button text="Iniciar sesión" onAction="#onLogin" maxWidth="200"/>
            <Button text="Registrarse" onAction="#onRegister" maxWidth="200"/>
            <Label fx:id="messageLabel" textFill="red"/>
        </VBox>
    </center>
</BorderPane>

