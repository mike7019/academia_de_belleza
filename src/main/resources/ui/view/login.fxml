<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.academia.ui.controller.LoginController"
           stylesheets="@../styles/dashboard.css"
           styleClass="content-pane">

    <!-- Tarjeta de login reutilizando el mismo estilo que el dashboard -->
    <VBox alignment="CENTER" spacing="10.0" styleClass="content-card">
        <Label text="Academia de Belleza" styleClass="content-title"/>
        <TextField fx:id="usernameField" promptText="Usuario" maxWidth="200"/>
        <PasswordField fx:id="passwordField" promptText="Contraseña" maxWidth="200"/>
        <Button text="Iniciar sesión" onAction="#onLogin" maxWidth="200"/>
        <Button text="Registrarse" onAction="#onRegister" maxWidth="200"/>
        <Label fx:id="messageLabel" textFill="red"/>
    </VBox>

</StackPane>

