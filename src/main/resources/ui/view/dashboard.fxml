<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.academia.ui.controller.DashboardController"
            prefWidth="1100" prefHeight="700"
            minWidth="800" minHeight="500"
            stylesheets="@../styles/dashboard.css"
            styleClass="root-pane">

    <!-- Topbar (header) -->
    <top>
        <HBox spacing="12.0" alignment="CENTER_LEFT" styleClass="topbar">
            <Label text="Academia de Belleza" styleClass="topbar-title" />
            <Label text="·" styleClass="topbar-separator" />
            <Label text="Dashboard" styleClass="topbar-subtitle" />
            <Pane HBox.hgrow="ALWAYS" />
            <Label fx:id="usuarioLabel" text="Usuario: invitado" styleClass="topbar-user" />
            <Button text="Cerrar sesión" onAction="#onLogout" styleClass="logout-button" />
        </HBox>
    </top>

    <!-- Sidebar de navegación -->
    <left>
        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    styleClass="sidebar-scroll" minWidth="220" prefWidth="220" maxHeight="Infinity">
        <VBox spacing="8.0" prefWidth="220.0" minHeight="-Infinity" styleClass="sidebar">
            <Label text="NAVEGACIÓN" styleClass="sidebar-header" />

            <Button fx:id="dashboardButton" text="Dashboard" onAction="#onDashboard" maxWidth="Infinity"
                    styleClass="sidebar-button">
                <graphic>
                    <Label text="🏠" styleClass="sidebar-icon" />
                </graphic>
            </Button>

            <Button fx:id="estudiantesButton" text="Estudiantes" onAction="#onEstudiantes" maxWidth="Infinity"
                    styleClass="sidebar-button">
                <graphic>
                    <Label text="👩" styleClass="sidebar-icon" />
                </graphic>
            </Button>

            <Button fx:id="maestrosButton" text="Maestros" onAction="#onMaestros" maxWidth="Infinity"
                    styleClass="sidebar-button">
                <graphic>
                    <Label text="👨‍🏫" styleClass="sidebar-icon" />
                </graphic>
            </Button>

            <Button fx:id="cursosButton" text="Cursos" onAction="#onCursos" maxWidth="Infinity"
                    styleClass="sidebar-button">
                <graphic>
                    <Label text="📚" styleClass="sidebar-icon" />
                </graphic>
            </Button>

            <Button fx:id="matriculasButton" text="Matrículas" onAction="#onMatriculas" maxWidth="Infinity"
                    styleClass="sidebar-button">
                <graphic>
                    <Label text="📝" styleClass="sidebar-icon" />
                </graphic>
            </Button>

            <Button fx:id="pagosButton" text="Pagos" onAction="#onPagos" maxWidth="Infinity"
                    styleClass="sidebar-button">
                <graphic>
                    <Label text="💳" styleClass="sidebar-icon" />
                </graphic>
            </Button>

            <Button fx:id="nominaButton" text="Nómina" onAction="#onNomina" maxWidth="Infinity"
                    styleClass="sidebar-button">
                <graphic>
                    <Label text="💼" styleClass="sidebar-icon" />
                </graphic>
            </Button>

            <Button fx:id="reportesButton" text="Reportes" onAction="#onReportes" maxWidth="Infinity"
                    styleClass="sidebar-button">
                <graphic>
                    <Label text="📊" styleClass="sidebar-icon" />
                </graphic>
            </Button>
        </VBox>
        </ScrollPane>
    </left>

    <!-- Área de contenido dinámico -->
    <center>
        <StackPane fx:id="contentPane" styleClass="content-pane" alignment="CENTER">
            <VBox spacing="12.0" styleClass="content-card"
                  maxWidth="Infinity" maxHeight="Infinity">
                <Label text="Bienvenido a la Academia de Belleza" styleClass="content-title" />
                <Label text="Selecciona un módulo del menú lateral para comenzar." wrapText="true"
                       styleClass="content-subtitle" />
            </VBox>
        </StackPane>
    </center>
</BorderPane>

