<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.academia.ui.controller.DashboardController"
            prefWidth="1100.0" prefHeight="700.0">
    <!-- stylesheet is added programmatically to avoid FXML parser differences -->
    <top>
        <!-- Mantener header original y añadir una fila de KPIs debajo en una VBox -->
        <VBox>
            <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-background-color: #2c3e50; -fx-padding: 10;">
                <Label text="Academia de Belleza - Dashboard"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="usuarioLabel" text="" style="-fx-text-fill: white;"/>
                <Button text="Cerrar sesión" onAction="#onLogout"/>
            </HBox>

            <!-- KPI cards row: alineadas horizontalmente, separadas y estilizadas -->
            <HBox fx:id="kpiRow" spacing="12.0" style="-fx-padding: 12 18 12 18; -fx-background-color: transparent;" alignment="CENTER_LEFT">
                <!-- Card: Cursos Abiertos -->
                <StackPane fx:id="cardCursos" styleClass="kpi-card">
                    <VBox spacing="6" alignment="CENTER_LEFT" style="-fx-padding: 12; -fx-pref-width: 220;">
                        <Label text="Cursos abiertos" styleClass="kpi-title" wrapText="true" maxWidth="200" />
                        <Label fx:id="cursosAbiertosLabel" text="-" styleClass="kpi-value" onMouseClicked="#onKpiCursosClicked" />
                    </VBox>
                </StackPane>

                <!-- Card: Cupos Disponibles -->
                <StackPane fx:id="cardCupos" styleClass="kpi-card">
                    <VBox spacing="6" alignment="CENTER_LEFT" style="-fx-padding: 12; -fx-pref-width: 220;">
                        <Label text="Cupos disponibles" styleClass="kpi-title" wrapText="true" maxWidth="200" />
                        <Label fx:id="cuposDisponiblesLabel" text="-" styleClass="kpi-value" onMouseClicked="#onKpiCuposClicked" />
                    </VBox>
                </StackPane>
            </HBox>
            <!-- Pequeña área para actividad reciente dentro del header -->
            <VBox fx:id="miniRecentBox" spacing="6" style="-fx-padding: 8 18 12 18; -fx-pref-height: 140; -fx-alignment: TOP_LEFT;">
                <Label text="Actividad reciente" style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13px;"/>
                <ListView fx:id="recentStudentsList" prefHeight="110" prefWidth="420" />
            </VBox>
        </VBox>
    </top>

    <left>
        <VBox spacing="8.0" style="-fx-background-color: #ecf0f1; -fx-padding: 10;">
            <Label text="Módulos" style="-fx-font-weight: bold; -fx-padding: 0 0 5 0;"/>
            <Button text="👩‍🎓  Estudiantes" onAction="#onEstudiantes" maxWidth="Infinity"/>
            <Button text="🧑‍🏫  Maestros" onAction="#onMaestros" maxWidth="Infinity"/>
            <Button text="📚  Cursos" onAction="#onCursos" maxWidth="Infinity"/>
            <Button text="📝  Matrículas" onAction="#onMatriculas" maxWidth="Infinity"/>
            <Button text="💳  Pagos" onAction="#onPagos" maxWidth="Infinity"/>
            <Button text="📥  Nómina" onAction="#onNomina" maxWidth="Infinity"/>
            <Button text="📊  Reportes" onAction="#onReportes" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane">
            <Label text="Bienvenido al sistema de gestión de la Academia de Belleza"
                   style="-fx-font-size: 16px;"/>
        </StackPane>
    </center>
</BorderPane>

