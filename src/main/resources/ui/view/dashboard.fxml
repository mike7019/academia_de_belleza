<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.academia.ui.controller.DashboardController"
            prefWidth="1100.0" prefHeight="700.0">
    <top>
        <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <Label text="Academia de Belleza - Dashboard"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="usuarioLabel" text="" style="-fx-text-fill: white;"/>
            <Button text="Cerrar sesión" onAction="#onLogout"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="8.0" style="-fx-background-color: #ecf0f1; -fx-padding: 10;">
            <Label text="Módulos" style="-fx-font-weight: bold; -fx-padding: 0 0 5 0;"/>
            <Button text="Dashboard" onAction="#onDashboard" maxWidth="Infinity"/>
            <Button text="Estudiantes" onAction="#onEstudiantes" maxWidth="Infinity"/>
            <Button text="Maestros" onAction="#onMaestros" maxWidth="Infinity"/>
            <Button text="Cursos" onAction="#onCursos" maxWidth="Infinity"/>
            <Button text="Matrículas" onAction="#onMatriculas" maxWidth="Infinity"/>
            <Button text="Pagos" onAction="#onPagos" maxWidth="Infinity"/>
            <Button text="Nómina" onAction="#onNomina" maxWidth="Infinity"/>
            <Button text="Reportes" onAction="#onReportes" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane">
            <VBox spacing="20.0" alignment="CENTER" style="-fx-padding: 20;">
                <Label text="Estadísticas de Estudiantes" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <HBox spacing="20.0" alignment="CENTER">
                    <VBox spacing="10.0" alignment="CENTER" style="-fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: #ecf0f1;">
                        <Label text="Total Estudiantes Activos" style="-fx-font-size: 14px;"/>
                        <Label fx:id="totalActivosLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                    </VBox>
                    <VBox spacing="10.0" alignment="CENTER" style="-fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: #ecf0f1;">
                        <Label text="Nuevos Registrados (Mes Actual)" style="-fx-font-size: 14px;"/>
                        <Label fx:id="nuevosRegistradosLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                    </VBox>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
